# MLFlow
MLFLOW_TRACKING_URI=http://<EXTERNAL_IP>:5000

# Supabase
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# GCP
GCP_PROJECT=docqflow
GCS_BUCKET=docqflow-pdfs-dev

# LLM
LLM_DEFAULT_PROFILE=cloud-fast
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-...

# CORS — comma-separated origins allowed by the backend. The defaults cover the
# Vercel frontend and local Vite/CRA dev servers; override only if you serve
# the SPA from a different origin.
CORS_ALLOWED_ORIGINS=https://docqflow.vercel.app,http://localhost:3000,http://localhost:5173
